{
  "schemaVersion": 3,
  "name": "square-kaleidoscope-fixed-point-negative-control",
  "width": 512,
  "height": 512,
  "tileWidth": 256,
  "tileHeight": 256,
  "tiling": 8,
  "diagnosticMode": "hardRound",
